<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Site Diary — @ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 antialiased">
    <nav class="bg-white shadow-sm">
        <div class="flex items-center justify-between h-16 px-6 max-w-7xl mx-auto">
            <span class="text-lg font-semibold text-gray-800">Site Diary</span>
            <a href="/AuditLogs"
               class="text-sm font-medium text-indigo-600 hover:text-indigo-800">Audit Log</a>
        </div>
    </nav>
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        @RenderBody()
    </main>
</body>
</html>
