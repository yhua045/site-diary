@model AuditLogPageDto

@{
    ViewData["Title"] = "Audit Logs";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Audit Log</h1>
    <p class="mt-2 text-sm text-gray-600">View all system changes ordered from oldest to newest.</p>
</div>

<!-- Audit Log Table -->
<div class="overflow-x-auto shadow-sm ring-1 ring-black ring-opacity-5 rounded-lg">
    <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
            <tr>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Timestamp
                </th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Entity
                </th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Action
                </th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Changed By
                </th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Changes
                </th>
            </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
            @foreach (var item in Model.Items)
            {
                <tr class="odd:bg-white even:bg-gray-50 hover:bg-gray-100">
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        @item.Timestamp.ToString("yyyy-MM-dd HH:mm:ss") UTC
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
                        @item.EntityName
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm">
                        @await Html.PartialAsync("_ActionBadge", item.Action)
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
                        @item.ChangedByUserName
                    </td>
                    <td class="px-6 py-4 text-sm text-gray-700">
                        @if (!string.IsNullOrEmpty(item.Changes))
                        {
                            <details class="cursor-pointer">
                                <summary class="text-indigo-600 hover:text-indigo-800 font-medium">View diff</summary>
                                <pre class="mt-2 p-2 bg-gray-100 rounded text-xs overflow-x-auto">@item.Changes</pre>
                            </details>
                        }
                        else
                        {
                            <span class="text-gray-400">—</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Items.Any())
{
    <div class="text-center py-12">
        <p class="text-lg text-gray-600">No audit log entries found.</p>
    </div>
}

<!-- Pagination Controls -->
@{
    var hasPreviousPage = Model.Page > 1;
    var hasNextPage = (Model.Page * Model.PageSize) < Model.TotalCount;
    var totalPages = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);
}

<div class="mt-8 flex items-center justify-between">
    <div class="text-sm text-gray-600">
        Showing <strong>@((Model.Page - 1) * Model.PageSize + 1)</strong> to 
        <strong>@Math.Min(Model.Page * Model.PageSize, Model.TotalCount)</strong> of 
        <strong>@Model.TotalCount</strong> entries
    </div>

    <div class="flex space-x-2">
        @if (hasPreviousPage)
        {
            <a href="@Url.Action("Index", new { page = Model.Page - 1, pageSize = Model.PageSize })"
               class="px-3 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50">
                ← Previous
            </a>
        }
        else
        {
            <span class="px-3 py-2 text-sm font-medium text-gray-400 bg-gray-100 border border-gray-300 rounded-md opacity-50 cursor-not-allowed">
                ← Previous
            </span>
        }

        <span class="px-3 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md">
            Page @Model.Page of @totalPages
        </span>

        @if (hasNextPage)
        {
            <a href="@Url.Action("Index", new { page = Model.Page + 1, pageSize = Model.PageSize })"
               class="px-3 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50">
                Next →
            </a>
        }
        else
        {
            <span class="px-3 py-2 text-sm font-medium text-gray-400 bg-gray-100 border border-gray-300 rounded-md opacity-50 cursor-not-allowed">
                Next →
            </span>
        }
    </div>
</div>
